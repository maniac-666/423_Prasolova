<Page x:Class="_423_Prasolova.Page1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Линейный алгоритм">
    <StackPanel Margin="20">
        <TextBlock Text="Вариант 4: Линейный расчет" FontSize="18" Margin="0,0,0,10"/>
        <Image Source="/Images/formula1.png" Height="100"/>
        <Label Content="Введите X:"/>
        <TextBox Name="txtX" ToolTip="Введите вещественное число x"/>
        <Label Content="Введите Y:"/>
        <TextBox Name="txtY" ToolTip="Введите вещественное число y"/>
        <Label Content="Введите Z:"/>
        <TextBox Name="txtZ" ToolTip="Введите вещественное число z"/>

        <Label Content="Результат W:"/>
        <TextBox Name="txtRes" IsReadOnly="True" Background="#EEE" ToolTip="Результат расчета"/>
        <StackPanel Orientation="Horizontal" Margin="0,10">
            <Button Content="Вычислить" Click="BtnCalc_Click" Width="100" Margin="0,0,10,0"/>
            <Button Content="Очистить" Click="BtnClear_Click" Width="100"/>
        </StackPanel>
    </StackPanel>
</Page>